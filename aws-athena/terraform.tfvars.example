# AWS Athena Terraform Variables Example
# Copy this file to terraform.tfvars and customize for your environment

############################
# General Configuration
############################
project_name = "athena-analytics"
region       = "eu-west-1"

tags = {
  Environment = "Development"
  ManagedBy   = "Terraform"
  Project     = "AWS Athena Analytics"
  Team        = "Data Engineering"
}

############################
# S3 Configuration
############################
enable_versioning = true
enable_encryption = true
# kms_key_id = "arn:aws:kms:eu-west-1:123456789012:key/12345678-1234-1234-1234-123456789012"

############################
# Glue ETL Configuration
############################
enable_glue_etl = true

glue_crawler = {
  table_prefix = "raw_"
  schedule     = null  # Use null for manual runs, or cron expression like "cron(0 2 * * ? *)"
}

glue_job_config = {
  script_path          = "scripts/glue-etl-job.py"
  input_table_prefix   = "raw_"
  output_path          = "processed/"
  output_format        = "parquet"  # Parquet recommended for Athena (better performance, lower cost)
  worker_type          = "G.1X"
  number_of_workers    = 2
  version              = "5.0"
  job_timeout          = 2880
  max_retries          = 1
  max_concurrent_runs  = 1
  enable_quality_checks = true
  quality_report_path   = "quality-reports/"
  bad_data_path         = "bad-data/"
  filter_bad_data       = true
  job_bookmark_option   = "job-bookmark-disable"
  enable_partitioning   = true
  partition_columns     = "year,month,day"
  enable_job_insights   = true
  enable_spark_ui       = true
  job_language          = "python"
  python_version        = "3"
  log_retention_days    = 7
}

############################
# Glue Data Catalog Configuration
############################
glue_database = {
  name        = "analytics_db"
  description = "Analytics database for Athena queries (processed data)"
}

