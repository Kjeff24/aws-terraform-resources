############################
# Athena Workgroup Configuration
############################
athena_workgroups = {
  primary = {
    description              = "Primary Athena workgroup for analytics"
    enforce_workgroup_config = false
    publish_cloudwatch_metrics = true
    result_configuration = {
      output_location = null  # Uses default: s3://query-results-bucket/primary/
      encryption_configuration = {
        encryption_option = "SSE_S3"
        kms_key           = null
      }
    }
    state = "ENABLED"
  }
  # Example: Additional workgroup for specific team
  # data_team = {
  #   description              = "Workgroup for data team"
  #   enforce_workgroup_config = true
  #   publish_cloudwatch_metrics = true
  #   result_configuration = {
  #     output_location = "s3://athena-analytics-query-results-xxxxx/data-team/"
  #     encryption_configuration = {
  #       encryption_option = "SSE_KMS"
  #       kms_key           = "arn:aws:kms:eu-west-1:123456789012:key/12345678-1234-1234-1234-123456789012"
  #     }
  #   }
  #   engine_version = {
  #     selected_engine_version = "Athena engine version 3"
  #   }
  #   state = "ENABLED"
  # }
}

############################
# IAM Configuration
############################
# Note: Athena user role is automatically created with name: ${project_name}-athena-user-role
